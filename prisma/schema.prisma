generator client {
  provider = "prisma-client"
  output   = "../src/server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id    String @id @default(cuid())
  // 워크스페이스(테넌트) 스코프 = Clerk orgId. KAN-14에서 FK 소급 — webhook 동기화
  // 순서 경합은 생성 트랜잭션의 스켈레톤 upsert가 흡수한다(services/notes.ts).
  // 조직 삭제 시 노트는 함께 파기된다(Cascade — KAN-12 수명 정책 결정).
  orgId String
  // 작성자 Clerk user id. FK 소급 이전 노트는 null, 작성자 탈퇴 시에도 null로 남는다.
  authorId String?

  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([authorId])
}

// 아래 세 모델은 Clerk의 사용자/조직/소속을 DB에 미러링한 것 — webhook으로만 채워진다.
// createdAt/updatedAt은 Clerk 원본 시각이 아니라 '이 행을 동기화한 시각'이다.

/// Clerk 사용자 미러. id는 Clerk user id(user_...). user.* 이벤트로 동기화.
model User {
  id        String   @id
  email     String?
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  notes       Note[]
}

/// Clerk 조직(=워크스페이스) 미러. id는 Clerk org id(org_...). organization.* 이벤트로 동기화.
model Organization {
  id        String   @id
  name      String
  slug      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  notes       Note[]
}

/// 사용자↔조직 소속과 역할. id는 Clerk membership id(orgmem_...). organizationMembership.* 이벤트로 동기화.
model Membership {
  id        String   @id
  orgId     String
  userId    String
  // Clerk 역할 문자열 (예: 'org:admin', 'org:member').
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}
